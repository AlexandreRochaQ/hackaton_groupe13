{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node",
      "config": { "memory": 1024, "maxDuration": 60 }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/app.js" },
    { "src": "/health", "dest": "/backend/app.js" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
